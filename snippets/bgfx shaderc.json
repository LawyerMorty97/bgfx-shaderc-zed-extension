{
  "BGFX Vertex Shader": {
    "prefix": "vs",
    "body": [
      "\\$input a_position",
      "\\$output v_texcoord0",
      "",
      "#include \"common.sh\"",
      "#include \"bgfx_shader.sh\"",
      "",
      "void main()",
      "{",
      "    ${1:gl_Position = vec4(a_position.xy, 0.999999, 1.0);}",
      "    $0",
      "}"
    ],
    "description": "BGFX vertex shader template"
  },
  "BGFX Fragment Shader": {
    "prefix": "fs",
    "body": [
      "\\$input v_texcoord0",
      "",
      "#include \"common.sh\"",
      "#include \"bgfx_shader.sh\"",
      "",
      "void main()",
      "{",
      "    $0",
      "}"
    ],
    "description": "BGFX fragment shader template"
  },
  "BGFX Compute Shader": {
    "prefix": "cs",
    "body": [
      "#include \"common.sh\"",
      "#include \"bgfx_shader.sh\"",
      "",
      "NUM_THREADS(${1:8}, ${2:8}, ${3:1})",
      "",
      "void main()",
      "{",
      "    $0",
      "}"
    ],
    "description": "BGFX compute shader template"
  }
}
